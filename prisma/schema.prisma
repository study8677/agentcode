generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChallengeMode {
  TASK
  REVIEW
}

enum ChallengeDifficulty {
  JUNIOR
  MID
  SENIOR
}

enum ChallengeStatus {
  DRAFT
  READY
  NEEDS_REVIEW
}

enum RunStatus {
  IDLE
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model Challenge {
  id             String              @id @default(cuid())
  slug           String              @unique
  title          String
  summary        String
  mode           ChallengeMode
  difficulty     ChallengeDifficulty
  status         ChallengeStatus     @default(DRAFT)
  acceptanceRate Float
  tags           String[]
  runStatus      RunStatus           @default(IDLE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}
