    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.22.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "4.23.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "prisma": "7.8.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.10"
