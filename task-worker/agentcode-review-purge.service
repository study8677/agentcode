[Unit]
Description=AgentCode anonymous review data retention purge
After=postgresql.service

[Service]
Type=oneshot
User=agentcode
Group=agentcode
EnvironmentFile=/etc/agentcode-deploy.env
Environment=NODE_ENV=production
Environment=PATH=/opt/node-v22/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/opt/agentcode
ExecStart=/opt/agentcode/node_modules/.bin/tsx /opt/agentcode/scripts/purge-review-data.ts
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
