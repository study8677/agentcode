+evalcache = {}
+
+def cached_eval(expr: str, d: Dict[str, object]) -> Any:
+    if expr in evalcache:
+        return evalcache[expr]
+    exprcode = _pytest._code.compile(expr, mode='eval')
+    evalcache[expr] = eval(exprcode, d)
+    return evalcache[expr]
