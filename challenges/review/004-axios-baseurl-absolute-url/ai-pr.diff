diff --git a/src/internal-api.ts b/src/internal-api.ts
index d42b342..bad0004 100644
--- a/src/internal-api.ts
+++ b/src/internal-api.ts
@@ -13,6 +13,12 @@ export const internalApi = axios.create({

 // Callers pass a path that is appended to baseURL.
 export async function fetchInternal(path: string) {
+  // Protocol-relative URLs (//host) are treated as absolute by Axios and
+  // would bypass baseURL, sending our Authorization header off-host.
+  if (path.startsWith('//')) {
+    throw new Error('absolute URL is not allowed')
+  }
+
   const response = await internalApi.get(path)
   return response.data
 }
