@@ -18,6 +18,17 @@ describe('route compilation', () => {
     const re = tokensToRegExp(parse('/:a'))
     expect(re.test('/users')).toBe(true)
   })

+  it('does not hang on two dashed params', () => {
+    const re = tokensToRegExp(parse('/:a-:b'))
+    // Previously this input caused catastrophic backtracking.
+    const input = '/' + 'a'.repeat(20000)
+    const start = Date.now()
+    expect(re.test(input)).toBe(false)
+    expect(Date.now() - start).toBeLessThan(100)
+  })
+
   it('matches a simple two-param route', () => {
     const re = tokensToRegExp(parse('/:a-:b'))
     expect(re.test('/foo-bar')).toBe(true)
   })
 })
