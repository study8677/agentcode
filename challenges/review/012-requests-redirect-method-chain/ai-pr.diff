+    def test_resolve_redirects_is_side_effect_free(self):
+        req = requests.Request('POST', httpbin('redirect-to'),
+                               params={'url': httpbin('get'), 'status_code': 303},
+                               data={'k': 'v'}).prepare()
+        s = requests.Session()
+        resp = s.send(req, allow_redirects=True)
+        # The caller's request object is left untouched by redirect handling.
+        assert req.method == 'POST'
+        assert resp.status_code == 200
