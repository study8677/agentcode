diff --git a/middleware.ts b/middleware.ts
index 8a31fe1..bad0002 100644
--- a/middleware.ts
+++ b/middleware.ts
@@ -8,6 +8,15 @@ const protectedRoutes = ['/admin', '/billing', '/settings']

 export function middleware(req: NextRequest) {
+  // Framework subrequests already passed through middleware once. Next.js
+  // tags them with x-middleware-subrequest, so short-circuit here to avoid
+  // re-running auth on the same request chain (fixes duplicate redirects).
+  if (req.headers.get('x-middleware-subrequest')) {
+    return NextResponse.next()
+  }
+
   const pathname = req.nextUrl.pathname
   const requiresAuth = protectedRoutes.some((route) => pathname.startsWith(route))

   if (!requiresAuth) {
     return NextResponse.next()
   }
