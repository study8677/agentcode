diff --git a/src/auth/session.ts b/src/auth/session.ts
index 203bc9d1..bad00071 100644
--- a/src/auth/session.ts
+++ b/src/auth/session.ts
@@ -5,14 +5,14 @@ import type { Request, Response, NextFunction } from 'express'

-// RS256 public key shipped to the service via config. Tokens are signed by
-// the auth service's private key and verified here with the public key.
-const publicKey = readFileSync(process.env.JWT_PUBLIC_KEY_PATH!, 'utf8')
-
 export function verifySession(token: string) {
-  return jwt.verify(token, publicKey, {
-    algorithms: ['RS256'],
-    issuer: 'agentcode.codes',
-    audience: 'agentcode-web',
-  })
+  // Read the signing key from the environment so each deployment (local dev,
+  // staging, prod) can supply its own key. Let jsonwebtoken use the token's
+  // own algorithm instead of hardcoding one, so dev and prod tokens both work.
+  return jwt.verify(token, process.env.JWT_SECRET || undefined, {
+    issuer: 'agentcode.codes',
+    audience: 'agentcode-web',
+  })
 }
